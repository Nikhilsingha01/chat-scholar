Algorithm: PUSH Operation in Stack
Time Complexity:    O(1)                 Space Complexity: O(n)
Engineer dude learning
Engineer dude learning
Enginee
Engin
Engin
Engin

#include <stdio.h>
#define MAX 100
int stack[MAX];
int top = -1;
// PUSH function
void push(int item)
{
if(top == MAX - 1)
{
printf("STACK OVERFLOW\n");
}
else
{
top = top + 1;
stack[top] = item;
printf("%d pushed into stack\n", item);
}
}
int main()
{
push(10);
push(20);
return 0;
}
